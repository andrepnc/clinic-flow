          "name": "HubSpot Service Key account"
        },
        "httpHeaderAuth": {
          "id": "CmnDBUyZTuDSgSbC",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Faz o parse defensivo da resposta do Gemini e junta com os dados do formulário.\nconst form = $('Recebe Lead').first().json;\nconst resp = $input.first().json;\n\nlet text = resp.candidates?.[0]?.content?.parts?.[0]?.text ?? '';\ntext = text.trim().replace(/^```(?:json)?/i, '').replace(/```$/, '').trim();\n\nlet cls;\ntry {\n  cls = JSON.parse(text);\n} catch (e) {\n  throw new Error('Resposta do Gemini não é JSON válido: ' + text);\n}\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    nome: form['Nome'],\n    email: form['Email'],\n    telefone: form['Telefone'] || '',\n    servico: cls.servico,\n    urgencia: cls.urgencia,\n    resumo: cls.resumo,\n    tom_sugerido: cls.tom_sugerido\n  }\n}];"
      },
      "id": "f9ab59ca-0ddc-4841-bfe9-5c11385ded79",

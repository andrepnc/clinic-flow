    {
      "parameters": {
        "jsCode": "// Seleciona bookings confirmados a menos de 24h da consulta e ainda sem lembrete.\nconst now = Date.now();\nconst JANELA_MS = 24 * 60 * 60 * 1000;\nconst out = [];\n\nfor (const item of $input.all()) {\n  const r = item.json;\n  if ((r.status || '') !== 'confirmada') continue;\n  if (r.lembrete_enviado) continue;\n  if (!r.data_consulta) continue;\n\n  const start = Date.parse(r.data_consulta);\n  if (Number.isNaN(start)) continue;\n\n  const falta = start - now;\n  if (falta > 0 && falta <= JANELA_MS) {\n    const fmt = new Intl.DateTimeFormat('pt-PT', {\n      dateStyle: 'full', timeStyle: 'short', timeZone: 'Europe/Lisbon'\n    });\n    out.push({\n      json: {\n        row_number: r.row_number,\n        nome: r.nome,\n        email: r.email,\n        data_consulta_formatada: fmt.format(new Date(start))\n      }\n    });\n  }\n}\n\nreturn out;"
      },

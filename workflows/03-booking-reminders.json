    {
      "parameters": {
        "jsCode": "// Interpreta o payload booking.created do Cal.com e normaliza para o formato do log.\nconst body = $input.first().json.body ?? $input.first().json;\nconst p = body.payload ?? body;\nconst attendee = (p.attendees && p.attendees[0]) || {};\n\nconst start = p.startTime || '';\nlet dataFormatada = '';\nif (start) {\n  const fmt = new Intl.DateTimeFormat('pt-PT', {\n    dateStyle: 'full', timeStyle: 'short', timeZone: 'Europe/Lisbon'\n  });\n  dataFormatada = fmt.format(new Date(start));\n}\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    nome: attendee.name || '',\n    email: attendee.email || '',\n    data_consulta: start,\n    status: 'confirmada',\n    lembrete_enviado: '',\n    followup_enviado: '',\n    data_consulta_formatada: dataFormatada\n  }\n}];"
      },
